sed\":false},\"1812828540\":{\"name\":\"1812828540\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"is_enabled\":true},\"is_device_based\":false,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2048788910\":{\"name\":\"2048788910\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":3,\"intervalMs\":200},\"is_device_based\":false,\"passed\":false},\"548821362\":{\"name\":\"548821362\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"eligible_upsell_context_ids\":[\"codex\",\"image_gen\"]},\"is_device_based\":false,\"passed\":false},\"3934129380\":{\"name\":\"3934129380\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"model\":\"gpt-4o\"},\"is_device_based\":false,\"passed\":false},\"1249441125\":{\"name\":\"1249441125\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"1939873467\":{\"name\":\"1939873467\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Live-only update\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1355628363\":{\"name\":\"1355628363\",\"rule_id\":\"6EkzgQkSDT4MxFNtb5sHlF:100.00:5-6EkzgOFQbAViegfxzXx42D\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"prompts\":[{\"title\":\"Make a mango tasting mat\",\"body\":\"Create a bright text-light mango tasting mat with simple sections for aroma, sweetness, texture and favourite, leaving labels blank.\"},{\"title\":\"Create a music Reel backdrop\",\"body\":\"Create a text-light vertical backdrop for a music Reel. Use lively abstract shapes, no platform logos, and leave empty space for my caption.\"},{\"title\":\"Map train booking choices\",\"body\":\"Create a simple train ticket status flowchart with icons for CNF, RAC, WL and Tatkal. Keep labels short and editable.\"},{\"body\":\"Help me build a 20-minute reading routine. Ask me one question about when I can read, then suggest a first-week plan.\",\"title\":\"Build a reading routine\"},{\"title\":\"Learn to plan a short trip\",\"body\":\"Teach me how to plan a short trip from scratch. Ask one question about destination and dates, then build a simple itinerary outline.\"},{\"body\":\"Give me a fun Wimbledon 2026 primer: what makes grass-court tennis different, who to notice, and how to sound less lost.\",\"title\":\"Get into Wimbledon gently\"},{\"title\":\"Pick a Wimbledon match\",\"body\":\"Check the current Wimbledon schedule and suggest one match to follow from India, with the likely match time and one story to watch.\"},{\"title\":\"Polish a WhatsApp message\",\"body\":\"I need to send a tricky WhatsApp message. Ask me to paste it and say who it is for, then make it polite and natural.\"},{\"title\":\"Turn revision into a game\",\"body\":\"Make my unit-test revision feel like a game. Ask my subject first, then give a 20-minute plan with quick rounds.\"},{\"body\":\"Make a rainy-day commute game plan. Ask my city and route first, then suggest backup transport, timing buffers and what to pack.\",\"title\":\"Plan a rainproof commute\"},{\"body\":\"Give me a fun, no-jargon catch-up on the Women’s T20 World Cup, with India’s path, key players to notice, and one thing to watch today.\",\"title\":\"Make a cricket catch-up card\"},{\"body\":\"Build a light India vs England watch plan for July: match reminders, snack breaks, and a simple way to follow if I miss overs.\",\"title\":\"Plan a late-night cricket watch\"},{\"title\":\"Build a kirana restock list\",\"body\":\"Make a monthly kirana restock list. Ask my household size first, then organise staples, cleaning items and quick top-ups.\"},{\"title\":\"Read monsoon updates better\",\"body\":\"Explain today’s India monsoon update in plain English, including what normal, deficit and warning colours mean.\"},{\"body\":\"Help me plan a monsoon journey with buffers for delays. Ask my city pair and travel mode, then make a practical backup plan.\",\"title\":\"Build a monsoon travel buffer\"},{\"title\":\"Host a spoiler-free film chat\",\"body\":\"Make a spoiler-free debate guide for a current Indian film my friends have seen. Ask the film name, then give talking points.\"},{\"body\":\"Check the Wimbledon 2026 schedule and make me a simple IST viewing plan for the first week. Ask which players I care about.\",\"title\":\"Plan your Wimbledon viewing\"},{\"title\":\"Make a study quest map\",\"body\":\"Create a simple study quest map with 7 checkpoints, icons and blank labels. Ask me the subject first, then give label text separately.\"},{\"title\":\"Make a pantry check poster\",\"body\":\"Create a text-light pantry label-check poster with icons for MRP, expiry, ingredients, veg or non-veg symbol and storage.\"},{\"body\":\"Create a simple text-light rainy entryway layout for an Indian flat: shoe zone, umbrella spot, drying mat and hooks. No brand names.\",\"title\":\"Draw a rainy entryway\"},{\"title\":\"Get documents ready online\",\"body\":\"Help me prepare a DigiLocker-ready document set for admissions or a government service. Ask which task first.\"},{\"body\":\"Make a monsoon laundry rota for a small home where clothes dry indoors. Include smell prevention, rainy-day backup and what to wash first.\",\"title\":\"Fix monsoon laundry\"},{\"title\":\"Prepare Passport Seva papers\",\"body\":\"Help me prepare for a Passport Seva appointment. Check official document guidance and ask one question about my application type.\"},{\"title\":\"Set up DigiLocker basics\",\"body\":\"Explain DigiLocker in everyday terms and help me plan which documents to fetch, upload, or carry as originals.\"},{\"title\":\"Learn ride phrases\",\"body\":\"Teach me 8 polite phrases for an auto or cab ride. Ask my city or language first, then give pronunciation help.\"},{\"body\":\"Practise a 5-minute small-talk scene with me. Ask the setting first, then play the other person and keep it light.\",\"title\":\"Practise small talk lightly\"},{\"body\":\"Teach me a difficult topic using everyday examples. Ask me the topic first, then build a 10-minute lesson.\",\"title\":\"Learn a topic with examples\"},{\"body\":\"Plan 3 spill-proof tiffin ideas. Ask what I eat and whether I can reheat first, then keep it practical.\",\"title\":\"Pack a better tiffin\"},{\"title\":\"Pack for hostel in the rains\",\"body\":\"Make a first hostel packing list for India’s monsoon months. Ask my city and hostel rules first, then group must-haves and nice-to-haves.\"},{\"title\":\"Review UPI AutoPay safely\",\"body\":\"Teach me how UPI AutoPay mandates work and give me a safe way to review subscriptions without sharing account details.\"},{\"body\":\"Practise a short meeting update with me. Give me a simple structure, then ask one question and correct my answer gently.\",\"title\":\"Practise a meeting update\"},{\"body\":\"Create a text-light packing map for a monsoon hostel or PG room: bedding, documents, footwear, laundry and desk. Use simple icons.\",\"title\":\"Draw a hostel packing map\"},{\"title\":\"Rain-proof my day\",\"body\":\"Help me make a practical monsoon plan for today: commute, footwear, laundry and bag essentials. Ask for my city first.\"},{\"title\":\"Understand the new India names\",\"body\":\"Explain the young players people are discussing in India’s Ireland and England T20Is. Keep it beginner-friendly and avoid hype.\"},{\"title\":\"Share a UPI split politely\",\"body\":\"Write a clear, polite message to request a UPI split for a group expense. Keep it short and include a line asking people to verify payee name.\"},{\"title\":\"Plan a World Cup night\",\"body\":\"Make me a simple FIFA World Cup watch plan for India time. Ask which teams I follow, then suggest matches, snacks and a sleep-friendly routine.\"},{\"body\":\"Create a simple chore wheel with household task icons and blank name spaces. Ask how many people should fit on it first.\",\"title\":\"Create a chore wheel\"},{\"title\":\"Pack for monsoon commutes\",\"body\":\"Build a monsoon commute kit for my city and travel mode. Ask one question if needed, then group items as must-carry and optional.\"},{\"body\":\"Use current India music charts to build a 7-song playlist theme for a rainy commute. Avoid explicit lyrics unless I ask.\",\"title\":\"Build a rainy commute playlist\"},{\"title\":\"Create a match-night scoreboard\",\"body\":\"Create a text-light match-night scoreboard image for the Women’s T20 World Cup. Keep spaces blank for teams, runs, snacks, and MVP.\"},{\"title\":\"Build a smarter grocery run\",\"body\":\"Make a grocery list that prevents random extras. Ask what I’m cooking this week, then group items by store section.\"},{\"body\":\"I’ll paste only my ticket status, not my full PNR. Explain CNF, RAC or WL and tell me the next sensible check.\",\"title\":\"Decode my train status\"},{\"title\":\"Cook from fridge leftovers\",\"body\":\"Help me turn fridge leftovers into an Indian-style meal. I can upload a photo or list what I have.\"},{\"title\":\"Plan a short trip in India\",\"body\":\"Help plan a 2–3 day trip in India. First ask my starting city and rough budget, then suggest practical options.\"},{\"body\":\"Pick a song currently high on YouTube India and explain its hook, structure and replay value without quoting lyrics.\",\"title\":\"Break down a charting song\"},{\"body\":\"Teach me pressure cooker basics for dal, rice and chana, including whistles, soaking and safety checks.\",\"title\":\"Learn cooker timing basics\"},{\"title\":\"Storyboard a song hook\",\"body\":\"Create a 6-frame, text-light storyboard template for explaining why a current YouTube India song hook works, with no lyrics or artist likenesses.\"},{\"body\":\"Give me a 30-minute game plan to sort household papers into keep, act and file piles. Ask what kind of papers I have first.\",\"title\":\"Sort papers without panic\"},{\"body\":\"Help me pick one low-maintenance native sapling for Van Mahotsav. Ask my city and planting space, then give care steps.\",\"title\":\"Pick a Van Mahotsav sapling\"},{\"title\":\"Learn the World Cup knockout\",\"body\":\"Explain the FIFA World Cup knockout format for an India viewer, including how extra time and penalties work.\"},{\"title\":\"Make a match-night tracker\",\"body\":\"Create a text-light FIFA World Cup match-night tracker with blank team slots, score spaces, and room for IST timings.\"},{\"title\":\"Decode a talked-about squad pick\",\"body\":\"Give me a quick profile of a current India squad pick being searched a lot. Cover role, recent context and what to watch for.\"},{\"title\":\"Play mock interview ping-pong\",\"body\":\"Run a mock interview like ping-pong. Ask my role, then give one question at a time with a short coaching note after each answer.\"},{\"title\":\"Plan a tiffin rotation\",\"body\":\"Build a 5-day school or office tiffin rotation using Indian staples. Ask one question about dietary limits before suggesting.\"},{\"title\":\"See field positions clearly\",\"body\":\"Create a simple T20 fielding map for a new cricket fan using dots and zones, with any position names listed outside the image.\"},{\"body\":\"Explain Form 16, AIS, 26AS and ITR in simple terms for AY 2026-27. Ask one question only if you need my income type.\",\"title\":\"Understand Form 16 and AIS\"},{\"title\":\"Sort tiny UPI payments\",\"body\":\"Help me make a tiny-payment routine for chai, autos and kirana. Check current UPI Lite rules and remind me not to share PINs.\"},{\"title\":\"Decode holiday types\",\"body\":\"Explain gazetted, restricted and state holidays in India using the 2026 calendar. Give a simple rule for checking office or school closures.\"},{\"body\":\"Turn weekly chores into a fair, playful rota. Ask how many people are sharing, then sugges