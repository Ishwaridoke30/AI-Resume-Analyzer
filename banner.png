e_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2688454279\":{\"name\":\"2688454279\",\"rule_id\":\"35Dg2O0a0xbncUKLdHChWi:100.00:2-35Dg2Ml7yf1STvcPCzGEDg\",\"secondary_exposures\":[{\"gate\":\"3214226695\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"3942202898\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"240634109\",\"gateValue\":\"false\",\"ruleID\":\"3Bfrw3Sig4w6HIXSyIYF34\"},{\"gate\":\"2019673878\",\"gateValue\":\"true\",\"ruleID\":\"6dwDONMgoLGrX38sVDO1kl:100.00:5\"},{\"gate\":\"242711730\",\"gateValue\":\"true\",\"ruleID\":\"7tGAs5pMfH3PdHCi99HCaB:100.00:9\"}],\"id_type\":\"userID\",\"value\":{\"wingman_model_picker_alternative_options\":[],\"wingman_model_picker_default_display_name\":\"Live\",\"rollout_policy\":\"available_default\",\"incall_banner_enabled\":false,\"incall_voice_model_picker_available\":true,\"home_takeover_enabled\":true,\"rollout_version\":2,\"unavailable_upsell_policy\":\"none\",\"home_takeover_animation_enabled\":false,\"unavailable_upsell_show_upgrade_cta\":false,\"wingman_model_name\":\"GPT-Live-1\"},\"is_device_based\":false,\"passed\":true},\"3423894538\":{\"name\":\"3423894538\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"developer_instructions\":\"The user opened the Memory settings entrypoint to understand what ChatGPT knows about them.\\nAnswer with a concise profile summary using clear headings.\\nSeparate stable facts and preferences from softer inferences when that distinction is useful.\\nDo not list raw memory records or internal implementation details.\\nIf there is little usable memory or personalization context, say that plainly and suggest what the user can tell ChatGPT to improve personalization.\",\"prefilled_prompt\":\"What do you know about me? Give me a 5 paragraph summary, with headings.\"},\"is_device_based\":false,\"passed\":false},\"349489989\":{\"name\":\"349489989\",\"rule_id\":\"default\",\"secondary